<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>CertTools.AzureCreateRootCert</RootNamespace>
    <Title>Self Signed Root CA Certificate Creation Tool for Azure KeyVault</Title>
    <AssemblyTitle>$(Title)</AssemblyTitle>
    <Description>A console application to create a x.509 root CA certificate to issue other CA or signing certificates.
The tool will create the certificate in the designated Azure Key Vault.</Description>
    <ApplicationIcon>AzureCreateRootCert.ico</ApplicationIcon>
    <OutputType>Exe</OutputType>
    <RuntimeIdentifiers>win-x64</RuntimeIdentifiers>
    <SupportedOSPlatformVersion>10.0.26100.0</SupportedOSPlatformVersion>
    <InvariantGlobalization>true</InvariantGlobalization>
    <TrimMode>partial</TrimMode>
    <PackageIcon>PackageLogo.png</PackageIcon>
    <PackageId>MK.CertTools.AzureCreateRootCert</PackageId>
    <PackageReadmeFile>readme.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="AzureCreateRootCert.ico" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\PackageLogo.png">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
    <None Update="readme.md">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Azure.Identity" />
    <PackageReference Include="Azure.Security.KeyVault.Certificates" />
    <PackageReference Include="CommandLineParser" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\AzureCertCore\AzureCertCore.csproj" />
  </ItemGroup>

</Project>
